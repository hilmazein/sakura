# ============================================================
# Sakura DMS — Frontend Environment Variables (TEMPLATE)
# Salin file ini menjadi .env dan sesuaikan nilainya.
# ============================================================

# URL backend API
# Development : /api  (Vite proxy meneruskan ke localhost:5000)
# Production  : https://api.sakura.sch.id/api
VITE_API_BASE_URL=/api

# Timeout request HTTP (milidetik)
VITE_API_TIMEOUT=10000

# Nama aplikasi
VITE_APP_NAME=Sakura DMS
