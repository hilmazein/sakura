# ===== Server =====
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ===== Database (MySQL / TiDB) =====
# Lokal (XAMPP): host=127.0.0.1, user=root, password=
# Produksi: TiDB Cloud (atau MySQL kompatibel lainnya)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sakura_dms
# DB_SSL=true   # aktifkan untuk TiDB Cloud (butuh koneksi SSL)

# ===== JWT =====
JWT_SECRET=ganti-dengan-rahasia-panjang-acak
JWT_EXPIRES_IN=1d

# ===== Upload =====
MAX_UPLOAD_MB=25

# ===== Firebase Storage (penyimpanan file dokumen) =====
# Ambil dari file JSON service account Firebase Admin SDK
# (Firebase Console → Project Settings → Service Accounts → Generate new private key)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
# Alternatif: isi seluruh JSON service account sebagai satu baris (opsional,
# jika diisi maka 3 variabel FIREBASE_PROJECT_ID/CLIENT_EMAIL/PRIVATE_KEY di atas diabaikan)
# FIREBASE_SERVICE_ACCOUNT_JSON=

# ===== SAKURA AI Chatbot =====
GEMINI_API_KEY=gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=25000
